{
  "schemaVersion": 3,
  "kind": "sdkwork.app",
  "app": {
    "key": "sdkwork-forum-pc",
    "name": "sdkwork-forum-pc",
    "displayName": "SDKWork Forum PC",
    "appType": "PC",
    "description": "Forum PC application for SDKWork communication capabilities."
  },
  "backend": {
    "domain": "communication",
    "capabilities": ["forum"],
    "apiSurfaces": [
      {
        "surface": "app-api",
        "authority": "sdkwork-forum-app-api",
        "prefix": "/app/v3/api"
      },
      {
        "surface": "backend-api",
        "authority": "sdkwork-forum-backend-api",
        "prefix": "/backend/v3/api"
      }
    ]
  },
  "runtime": {
    "modes": ["web", "desktop", "tablet-ipados", "tablet-android"],
    "rootDirectories": [
      "config",
      "docs",
      "packages",
      "public",
      "scripts",
      "sdks",
      "specs",
      "src",
      "tests"
    ]
  },
  "release": {
    "version": "0.1.0",
    "channel": "dev"
  },
  "metadata": {
    "standardVersion": "2026-06-12",
    "architectureStandard": "APP_PC_ARCHITECTURE_SPEC.md"
  }
}
