# Forum Local Development Configuration
# Copy to .env.local and adjust values for your local environment

# Unified workspace PostgreSQL profile (ENVIRONMENT_SPEC.md §7.1)
SDKWORK_CLAW_DATABASE_ENGINE=postgresql
SDKWORK_CLAW_DATABASE_HOST=127.0.0.1
SDKWORK_CLAW_DATABASE_PORT=5432
SDKWORK_CLAW_DATABASE_NAME=sdkwork_ai_dev
SDKWORK_CLAW_DATABASE_SCHEMA=sdkwork_ai_dev
SDKWORK_CLAW_DATABASE_USERNAME=sdkwork_ai_dev
SDKWORK_CLAW_DATABASE_PASSWORD=sdkworkdev123
SDKWORK_CLAW_DATABASE_SSL_MODE=disable
SDKWORK_CLAW_DATABASE_MAX_CONNECTIONS=10
# SDKWORK_CLAW_DATABASE_URL=postgresql://sdkwork_ai_dev:sdkworkdev123@127.0.0.1:5432/sdkwork_ai_dev?sslmode=disable

# Search (sdkwork-search-backend-api gateway or service root)
SDKWORK_FORUM_SEARCH_URL=http://localhost:8080
SDKWORK_FORUM_SEARCH_INDEX_ID=forum

# Private bootstrap access token for protected search backend-api calls.
SDKWORK_ACCESS_TOKEN=

# Notifications (optional HTTP adapter)
SDKWORK_FORUM_NOTIFICATION_URL=

# Drive
SDKWORK_FORUM_DRIVE_URL=http://localhost:8080

# Log integration port calls when external URLs are unset
SDKWORK_FORUM_INTEGRATION_LOG=true

# Logging
RUST_LOG=debug

# Server
SDKWORK_FORUM_SERVER_PORT=8080
SDKWORK_FORUM_SERVER_HOST=0.0.0.0

# Default request context when IAM headers are absent (local dev only)
SDKWORK_FORUM_DEFAULT_TENANT_ID=100001
SDKWORK_FORUM_DEFAULT_ORGANIZATION_ID=0
SDKWORK_FORUM_DEFAULT_USER_ID=1

# IAM session resolution from dual tokens (uses unified DB unless IAM URL is set)
SDKWORK_FORUM_IAM_ENABLED=false
SDKWORK_FORUM_IAM_DATABASE_URL=
SDKWORK_FORUM_IAM_STRICT=false

# Require Authorization + Access-Token on app/backend forum routes
SDKWORK_FORUM_REQUIRE_AUTH=false

# Worker
SDKWORK_FORUM_WORKER_CONCURRENCY=4
SDKWORK_FORUM_WORKER_POLL_INTERVAL_MS=5000
