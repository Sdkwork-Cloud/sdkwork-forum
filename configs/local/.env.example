# Forum Local Development Configuration
# Copy to .env.local and adjust values for your local environment

# Database
SDKWORK_FORUM_DATABASE_URL=postgres://forum:forum@localhost:5432/forum

# Search
SDKWORK_FORUM_SEARCH_URL=http://localhost:9200

# Notifications (optional HTTP adapter)
SDKWORK_FORUM_NOTIFICATION_URL=

# Drive
SDKWORK_FORUM_DRIVE_URL=http://localhost:8080

# Log integration port calls when external URLs are unset
SDKWORK_FORUM_INTEGRATION_LOG=true

# Logging
RUST_LOG=debug

# Server
SDKWORK_FORUM_SERVER_PORT=8080
SDKWORK_FORUM_SERVER_HOST=0.0.0.0

# Default request context when IAM headers are absent (local dev only)
SDKWORK_FORUM_DEFAULT_TENANT_ID=1
SDKWORK_FORUM_DEFAULT_ORGANIZATION_ID=0
SDKWORK_FORUM_DEFAULT_USER_ID=1

# Require Authorization + Access-Token on app/backend forum routes
SDKWORK_FORUM_REQUIRE_AUTH=false

# Database ops (lifecycle/drift HTTP routes)
SDKWORK_OPS_DATABASE_AUTH_TOKEN=dev-ops-token

# Worker
SDKWORK_FORUM_WORKER_CONCURRENCY=4
SDKWORK_FORUM_WORKER_POLL_INTERVAL_MS=5000
