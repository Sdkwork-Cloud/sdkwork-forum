# Forum Production Configuration
# DO NOT commit actual secrets. Use secret references.

# Database (use secret reference)
# SDKWORK_FORUM_DATABASE_URL=<secret:forum/database-url>

# Search (use secret reference)
# SDKWORK_FORUM_SEARCH_URL=<secret:forum/search-url>

# Drive (use secret reference)
# SDKWORK_FORUM_DRIVE_URL=<secret:forum/drive-url>

# Logging
RUST_LOG=info

# Server
SDKWORK_FORUM_SERVER_PORT=8080
SDKWORK_FORUM_SERVER_HOST=0.0.0.0

# Worker
SDKWORK_FORUM_WORKER_CONCURRENCY=8
SDKWORK_FORUM_WORKER_POLL_INTERVAL_MS=1000

# Security
SDKWORK_FORUM_TOKEN_VALIDATION=strict
SDKWORK_FORUM_TENANT_ISOLATION=strict
